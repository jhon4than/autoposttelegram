services:
  telegram-bot-api:
    image: aiogram/telegram-bot-api:latest
    restart: unless-stopped
    environment:
      TELEGRAM_API_ID: ${TELEGRAM_API_ID}
      TELEGRAM_API_HASH: ${TELEGRAM_API_HASH}
      TELEGRAM_LOCAL: "1"
    volumes:
      - telegram-bot-api-state:/var/lib/telegram-bot-api
      - autoposttelegram-data:/data
    networks:
      - dokploy-network

volumes:
  telegram-bot-api-state:
  autoposttelegram-data:
    external: true

networks:
  dokploy-network:
    external: true
